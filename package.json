{
  "name": "@simplexd/simple-skills",
  "version": "0.1.2",
  "description": "Install the Simple Skills Agent Skill suite.",
  "type": "module",
  "bin": {
    "simple-skills": "bin/install.js"
  },
  "files": [
    "bin/",
    "skills/thread-to-skill/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "install:local": "node bin/install.js --codex --local --force",
    "pack:dry-run": "npm pack --dry-run",
