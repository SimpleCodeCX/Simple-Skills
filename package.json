    "simple-skills",
    "thread-to-skill",
    "knowledge-management"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SimpleCodeCX/Simple-Skills.git"
  },
  "bugs": {
    "url": "https://github.com/SimpleCodeCX/Simple-Skills/issues"
  },
  "homepage": "https://github.com/SimpleCodeCX/Simple-Skills#readme",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18"
  }
